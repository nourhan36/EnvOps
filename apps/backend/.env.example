# Existing application services
DATABASE_URL="postgresql://envops_admin:local_dev_password@localhost:5432/envops"
REDIS_URL="redis://localhost:6379"

# HTTP / Socket.IO server
PORT=3000
APP_ORIGINS="http://localhost:5173,http://localhost:3000"

# Local Kubernetes access.
# Leave KUBECONFIG empty when kubectl already uses %USERPROFILE%\.kube\config.
KUBECTL_BIN="kubectl"
KUBECONFIG=""
KUBECTL_CONTEXT=""

# must put this label on every sandbox Pod.
# Example: envops.io/sandbox-id=<database sandbox UUID>
SANDBOX_POD_LABEL_KEY="envops.io/sandbox-id"

# Shell opened inside the sandbox container.
# /bin/sh is more portable than /bin/bash.
TERMINAL_SHELL="/bin/sh"
TERMINAL_DEFAULT_COLS=100
TERMINAL_DEFAULT_ROWS=30
TERMINAL_MAX_INPUT_BYTES=65536

# TEMPORARY MVP AUTHENTICATION.
# replace this with the authenticated user from the Socket.IO handshake.
DEMO_USER_EMAIL="demo@envops.local"
