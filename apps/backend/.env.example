# Existing application services
DATABASE_URL="postgresql://username:password@hostname:port/database_name"
REDIS_URL="redis://hostname:port"

# HTTP / Socket.IO server
PORT=3000
APP_ORIGINS="http://hostname:port"

# Local Kubernetes access.
# Leave KUBECONFIG empty when kubectl already uses %USERPROFILE%\.kube\config.
KUBECTL_BIN="kubectl"
KUBECONFIG=""
KUBECTL_CONTEXT=""

# Kubernetes API target for the orchestrator.
# Use "emulator" for Floci/local development and "aws" for a real EKS cluster.
KUBERNETES_TARGET="emulator"
# Optional override for the local emulator API server.
KUBERNETES_EMULATOR_SERVER="https://IP:port"

# Pod selector used by the terminal backend.
# The search is restricted to the trusted sandbox namespace.
SANDBOX_POD_SELECTOR="app=sandbox"

# Shell opened inside the sandbox container.
# /bin/sh is more portable than /bin/bash.
TERMINAL_SHELL="/bin/sh"
TERMINAL_DEFAULT_COLS=100
TERMINAL_DEFAULT_ROWS=30
TERMINAL_MAX_INPUT_BYTES=65536

# TEMPORARY MVP AUTHENTICATION.
# replace this with the authenticated user from the Socket.IO handshake.
DEMO_USER_EMAIL="demo@envops.local"
