// Generates the Prisma Client used by the backend to query the database
generator client {
  provider = "prisma-client-js"
}

// Connects Prisma to PostgreSQL using DATABASE_URL from the backend environment
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application user account
/// Users can own login sessions and one or more provisioned sandboxes
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  /// Simple role string used for authorization, such as "developer"
  role      String    @default("developer")
  /// Stored in the database as created_at.
  createdAt DateTime  @default(now()) @map("created_at")
  sessions  Session[]
  sandboxes Sandbox[]

  // Maps this Prisma model to the existing users table
  @@map("users")
}

/// Authentication session for a user
/// Each row stores a token and its expiration time
model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  /// Required relation back to the user who owns this session
  user      User     @relation(fields: [userId], references: [id])
  token     String
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@map("sessions")
}

/// Reusable definition for creating sandboxes
/// Templates describe the container image, default resource limits and TTL
model SandboxTemplate {
  id                String    @id @default(uuid())
  /// Stable unique template key used by backend code
  name              String    @unique
  /// Human-friendly name shown in UI/API responses
  displayName       String    @map("display_name")
  description       String?
  /// Docker image used when provisioning a sandbox from this template
  dockerImage       String    @map("docker_image")
  /// Default CPU, memory, or other runtime limits stored as flexible JSON
  defaultLimits     Json      @map("default_limits")
  /// Default sandbox lifetime in minutes before expiration
  defaultTtlMinutes Int       @default(60) @map("default_ttl_minutes")
  /// Allows templates to be disabled without deleting historical references
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  /// Sandboxes created from this template
  sandboxes         Sandbox[]

  @@map("sandbox_templates")
}

/// A provisioned sandbox environment owned by a user
/// Tracks lifecycle status, expiration, runtime limits, logs and metrics
model Sandbox {
  id             String          @id @default(uuid())
  userId         String          @map("user_id")
  /// User who requested or owns the sandbox
  user           User            @relation(fields: [userId], references: [id])
  templateId     String          @map("template_id")
  /// Template used to provision this sandbox
  template       SandboxTemplate @relation(fields: [templateId], references: [id])
  /// Kubernetes namespace or isolation boundary assigned to this sandbox
  namespace      String
  /// Lifecycle state, for example provisioning, running, failed, or deleted
  status         String          @default("provisioning")
  /// Per-sandbox overrides for resource limits, when different from the template
  resourceLimits Json?           @map("resource_limits")
  createdAt      DateTime        @default(now()) @map("created_at")
  /// Time when the sandbox should be considered expired.
  expiresAt      DateTime        @map("expires_at")
  /// Soft-delete timestamp; null means the sandbox is still active/not deleted
  deletedAt      DateTime?       @map("deleted_at")
  logs           SandboxLog[]
  metrics        Metric[]

  // Indexes support common cleanup/filter queries by expiration and status
  @@index([expiresAt])
  @@index([status])
  @@map("sandboxes")
}

/// Log event emitted for a sandbox
/// Used to store provisioning, runtime, or cleanup messages
model SandboxLog {
  id        String   @id @default(uuid())
  sandboxId String   @map("sandbox_id")
  /// Sandbox that produced this log entry
  sandbox   Sandbox  @relation(fields: [sandboxId], references: [id])
  /// Category of log, such as provision, runtime, or cleanup
  logType   String   @map("log_type")
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sandbox_logs")
}

/// Point-in-time resource usage sample for a sandbox.
/// CPU and memory are optional so partial metric samples can be stored
model Metric {
  id          String   @id @default(uuid())
  sandboxId   String   @map("sandbox_id")
  /// Sandbox this metric sample belongs to
  sandbox     Sandbox  @relation(fields: [sandboxId], references: [id])
  cpuUsage    Decimal? @map("cpu_usage")
  memoryUsage Decimal? @map("memory_usage")
  /// Timestamp when this metric sample was collected
  recordedAt  DateTime @default(now()) @map("recorded_at")

  @@map("metrics")
}
